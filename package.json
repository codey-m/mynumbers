{
  "name": "numbers-puzzle-game",
  "version": "0.2.0",
  "description": "Arithmetic puzzle game: combine given numbers to reach a target.",
  "main": "dist/server/server.js",
  "scripts": {
    "build": "tsc && tsc -p tsconfig.client.json && webpack --config webpack.config.js",
    "build:server": "tsc",
    "build:client": "tsc -p tsconfig.client.json && webpack --config webpack.config.js",
    "start": "node dist/server/server.js",
    "dev": "tsc && tsc -p tsconfig.client.json && webpack --config webpack.config.js --mode development && node --watch dist/server/server.js"
  },
  "dependencies": {
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "ts-loader": "^9.5.7",
    "typescript": "^5.9.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^6.0.1"
  }
}
